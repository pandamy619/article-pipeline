# Скопируй в .env и заполни своими значениями.
# ВАЖНО: комментарии — только на отдельных строках. Не пиши их после значения
# (например `HABR_HUBS=python  # коммент`) — текст комментария попадёт в значение.

# --- Telegram бот (публикация в канал) ---
# токен от @BotFather
TELEGRAM_BOT_TOKEN=
# @username или -100… ; бот должен быть админом канала
TELEGRAM_CHANNEL_ID=
# твой user id — туда бот шлёт черновики на модерацию
ADMIN_USER_ID=

# --- Telethon (чтение чужих TG-каналов, user-аккаунт) ---
# с https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- LLM (Ollama) ---
# модель генерации/чата; прод: qwen3:14b
LLM_MODEL=qwen3:4b
# модель эмбеддингов (семантический дедуп)
EMBED_MODEL=bge-m3

# --- SearXNG ---
# сгенерируй: openssl rand -hex 32
SEARXNG_SECRET=

# --- PostgreSQL ---
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pipeline

# --- Источники ---
# Обычные RSS-сайты: ленты через запятую
RSS_FEEDS=https://tproger.ru/feed/,https://proglib.io/feed

# Habr (русский, рекомендуется).
# HABR_HUBS — алиасы хабов через запятую (напр. programming,python). Пусто = общая RU-лента.
HABR_ENABLED=true
HABR_HUBS=

# arXiv (англоязычный).
# ARXIV_CATEGORIES — коды через запятую (напр. cs.SE,cs.PL,cs.AI). Пусто = выключено.
ARXIV_CATEGORIES=
ARXIV_MAX_RESULTS=10

# Reddit (англоязычный).
# REDDIT_SUBREDDITS — имена без r/ через запятую (напр. learnprogramming). Пусто = выключено.
# Внимание: Reddit может отдавать 403 с некоторых IP (дата-центры) — тогда источник просто пустой.
REDDIT_SUBREDDITS=
REDDIT_PERIOD=week
REDDIT_LIMIT=10

# --- Поведение ---
# порог релевантности 0-10
RELEVANCE_THRESHOLD=7
# тематика для AI-фильтра
CHANNEL_TOPIC=статьи для начинающих программистов: туториалы, основы, разбор базовых концепций
# как часто гонять пайплайн (минуты)
RUN_INTERVAL_MINUTES=60
# 0 = без лимита; для теста можно поставить 5
MAX_ARTICLES_PER_RUN=0
