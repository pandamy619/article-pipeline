# Скопируй в .env и заполни своими значениями

# --- Telegram бот (публикация в группу) ---
TELEGRAM_BOT_TOKEN=       # токен от @BotFather
TELEGRAM_GROUP_ID=        # id группы для постинга (например -1001234567890)
ADMIN_USER_ID=            # твой user id — туда бот шлёт черновики на модерацию

# --- Telethon (чтение чужих TG-каналов, user-аккаунт) ---
TELEGRAM_API_ID=          # с https://my.telegram.org
TELEGRAM_API_HASH=

# --- PostgreSQL ---
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pipeline

# --- Источники / поведение ---
RSS_FEEDS=                # список RSS через запятую
SUBREDDITS=               # сабреддиты через запятую
ARXIV_CATEGORIES=         # напр. cs.AI,cs.CL
RELEVANCE_THRESHOLD=7     # порог релевантности 0-10
