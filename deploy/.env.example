# Скопируй в .env и заполни своими значениями

# --- Telegram бот (публикация в группу) ---
TELEGRAM_BOT_TOKEN=       # токен от @BotFather
TELEGRAM_CHANNEL_ID=      # @username или -100… ; бот должен быть админом канала
ADMIN_USER_ID=            # твой user id — туда бот шлёт черновики на модерацию

# --- Telethon (чтение чужих TG-каналов, user-аккаунт) ---
TELEGRAM_API_ID=          # с https://my.telegram.org
TELEGRAM_API_HASH=

# --- LLM (Ollama) ---
LLM_MODEL=qwen3:4b        # модель генерации/чата; прод: qwen3:14b; чистый чат: qwen2.5:7b (non-thinking)
EMBED_MODEL=bge-m3        # модель эмбеддингов (семантический дедуп)

# --- SearXNG ---
SEARXNG_SECRET=           # сгенерируй: openssl rand -hex 32

# --- PostgreSQL ---
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pipeline

# --- Источники / поведение ---
RSS_FEEDS=https://tproger.ru/feed/,https://proglib.io/feed   # список RSS через запятую
SUBREDDITS=               # сабреддиты через запятую
ARXIV_CATEGORIES=         # напр. cs.AI,cs.CL
RELEVANCE_THRESHOLD=7     # порог релевантности 0-10
RUN_INTERVAL_MINUTES=60   # как часто гонять пайплайн (минуты)
MAX_ARTICLES_PER_RUN=0    # 0 = без лимита; для теста можно поставить 5
